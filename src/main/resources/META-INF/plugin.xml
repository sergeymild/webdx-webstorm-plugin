<idea-plugin>
    <id>com.webdx.css-modules-scoped-usages</id>
    <name>WebDX</name>
    <vendor>WebDX</vendor>

    <description><![CDATA[
        Developer-experience helpers for a React/TypeScript project, all resolved
        from source files so they work even when the TypeScript language service
        does not (e.g. on the TypeScript-Go / tsgo engine).
        <ul>
          <li><b>CSS Modules</b>: scoped Find Usages on a class, sibling-module
              auto-import, <code>styles.</code> class-name completion, and
              unknown/unused-class inspections.</li>
          <li><b>i18n (react-i18next)</b>: translation-key completion, an
              unknown-key inspection, go-to-definition and scoped Find Usages on a
              key, plus interpolation-variable completion, checks, and
              go-to-placeholder for <code>t('key', { … })</code>.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.css</depends>
    <depends>JavaScript</depends>

    <extensions defaultExtensionNs="com.intellij">
        <findUsagesHandlerFactory
            order="first"
            implementation="com.webdx.cssmodules.CssModuleFindUsagesHandlerFactory"/>
        <findUsagesHandlerFactory
            order="first"
            implementation="com.webdx.rnstyles.RnStyleFindUsagesHandlerFactory"/>
        <gotoDeclarationHandler
            implementation="com.webdx.cssmodules.CssModuleGotoDeclarationHandler"/>
        <intentionAction>
            <className>com.webdx.cssmodules.CssModuleImportSymbolIntention</className>
            <category>CSS</category>
        </intentionAction>
        <lang.directNavigationProvider
            implementation="com.webdx.cssmodules.CssModuleDirectNavigationProvider"/>
        <postStartupActivity implementation="com.webdx.cssmodules.CssScopedStartup"/>

        <completion.contributor language="TypeScript JSX" id="cssModStylesTsx" order="first"
            implementationClass="com.webdx.cssmodules.CssModuleStylesCompletion"/>
        <completion.contributor language="TypeScript" id="cssModStylesTs" order="first"
            implementationClass="com.webdx.cssmodules.CssModuleStylesCompletion"/>
        <completion.contributor language="JavaScript" id="cssModStylesJs" order="first"
            implementationClass="com.webdx.cssmodules.CssModuleStylesCompletion"/>
        <completion.contributor language="ECMAScript 6" id="cssModStylesEs6" order="first"
            implementationClass="com.webdx.cssmodules.CssModuleStylesCompletion"/>
        <completion.contributor language="JSX Harmony" id="cssModStylesJsx" order="first"
            implementationClass="com.webdx.cssmodules.CssModuleStylesCompletion"/>

        <completion.contributor language="TypeScript JSX" id="rnStyleImportTsx"
            implementationClass="com.webdx.rnstyles.RnStyleImportCompletion"/>
        <completion.contributor language="TypeScript" id="rnStyleImportTs"
            implementationClass="com.webdx.rnstyles.RnStyleImportCompletion"/>
        <completion.contributor language="JavaScript" id="rnStyleImportJs"
            implementationClass="com.webdx.rnstyles.RnStyleImportCompletion"/>
        <completion.contributor language="ECMAScript 6" id="rnStyleImportEs6"
            implementationClass="com.webdx.rnstyles.RnStyleImportCompletion"/>
        <completion.contributor language="JSX Harmony" id="rnStyleImportJsx"
            implementationClass="com.webdx.rnstyles.RnStyleImportCompletion"/>

        <localInspection language="SCSS"
            shortName="CssModuleUnusedClass"
            displayName="Unused CSS module class"
            groupName="CSS"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.webdx.cssmodules.CssModuleUnusedClassInspection"/>
        <localInspection language="SASS"
            shortName="CssModuleUnusedClassSass"
            displayName="Unused CSS module class"
            groupName="CSS"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.webdx.cssmodules.CssModuleUnusedClassInspection"/>
        <localInspection language="LESS"
            shortName="CssModuleUnusedClassLess"
            displayName="Unused CSS module class"
            groupName="CSS"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.webdx.cssmodules.CssModuleUnusedClassInspection"/>
        <localInspection language="CSS"
            shortName="CssModuleUnusedClassCss"
            displayName="Unused CSS module class"
            groupName="CSS"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.webdx.cssmodules.CssModuleUnusedClassInspection"/>

        <!-- Register once on CSS only: SCSS/SASS/LESS are dialects of CSS, so a single
             CSS registration matches each file exactly once. Registering per-dialect
             made .scss match SCSS+SASS+CSS and fire the warning three times. -->
        <localInspection language="CSS"
            shortName="CssModuleOverrideClass"
            displayName="CSS module class overrides imported class"
            groupName="CSS" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.cssmodules.CssModuleOverrideClassInspection"/>

        <localInspection language="TypeScript JSX"
            shortName="CssModuleUnknownClassTsx"
            displayName="Unknown CSS module class"
            groupName="CSS" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.cssmodules.CssModuleUnknownClassInspection"/>
        <localInspection language="TypeScript"
            shortName="CssModuleUnknownClassTs"
            displayName="Unknown CSS module class"
            groupName="CSS" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.cssmodules.CssModuleUnknownClassInspection"/>
        <localInspection language="JavaScript"
            shortName="CssModuleUnknownClassJs"
            displayName="Unknown CSS module class"
            groupName="CSS" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.cssmodules.CssModuleUnknownClassInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="CssModuleUnknownClassEs6"
            displayName="Unknown CSS module class"
            groupName="CSS" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.cssmodules.CssModuleUnknownClassInspection"/>
        <localInspection language="JSX Harmony"
            shortName="CssModuleUnknownClassJsx"
            displayName="Unknown CSS module class"
            groupName="CSS" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.cssmodules.CssModuleUnknownClassInspection"/>

        <!-- groupName="JavaScript": these run on JS/TS sources (like the i18n inspections), not CSS files. -->
        <localInspection language="TypeScript JSX"
            shortName="RnStyleUnknownKeyTsx"
            displayName="Unknown React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.rnstyles.RnStyleUnknownKeyInspection"/>
        <localInspection language="TypeScript"
            shortName="RnStyleUnknownKeyTs"
            displayName="Unknown React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.rnstyles.RnStyleUnknownKeyInspection"/>
        <localInspection language="JavaScript"
            shortName="RnStyleUnknownKeyJs"
            displayName="Unknown React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.rnstyles.RnStyleUnknownKeyInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="RnStyleUnknownKeyEs6"
            displayName="Unknown React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.rnstyles.RnStyleUnknownKeyInspection"/>
        <localInspection language="JSX Harmony"
            shortName="RnStyleUnknownKeyJsx"
            displayName="Unknown React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="ERROR"
            implementationClass="com.webdx.rnstyles.RnStyleUnknownKeyInspection"/>

        <localInspection language="TypeScript JSX"
            shortName="RnStyleUnusedKeyTsx"
            displayName="Unused React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.rnstyles.RnStyleUnusedKeyInspection"/>
        <localInspection language="TypeScript"
            shortName="RnStyleUnusedKeyTs"
            displayName="Unused React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.rnstyles.RnStyleUnusedKeyInspection"/>
        <localInspection language="JavaScript"
            shortName="RnStyleUnusedKeyJs"
            displayName="Unused React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.rnstyles.RnStyleUnusedKeyInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="RnStyleUnusedKeyEs6"
            displayName="Unused React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.rnstyles.RnStyleUnusedKeyInspection"/>
        <localInspection language="JSX Harmony"
            shortName="RnStyleUnusedKeyJsx"
            displayName="Unused React Native style key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.rnstyles.RnStyleUnusedKeyInspection"/>

        <localInspection language="TypeScript JSX"
            shortName="DeadReExportTsx"
            displayName="Dead re-export (unused barrel link)"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.deadexports.DeadReExportInspection"/>
        <localInspection language="TypeScript"
            shortName="DeadReExportTs"
            displayName="Dead re-export (unused barrel link)"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.deadexports.DeadReExportInspection"/>
        <localInspection language="JavaScript"
            shortName="DeadReExportJs"
            displayName="Dead re-export (unused barrel link)"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.deadexports.DeadReExportInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="DeadReExportEs6"
            displayName="Dead re-export (unused barrel link)"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.deadexports.DeadReExportInspection"/>
        <localInspection language="JSX Harmony"
            shortName="DeadReExportJsxHarmony"
            displayName="Dead re-export (unused barrel link)"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.deadexports.DeadReExportInspection"/>
    </extensions>

    <extensions defaultExtensionNs="JavaScript">
        <importCandidatesFactory
            implementation="com.webdx.cssmodules.CssModuleImportCandidatesFactory"/>
        <importCandidatesFilterFactory
            implementation="com.webdx.cssmodules.CssModuleImportFilterFactory"/>
    </extensions>

    <!-- i18n: go-to-definition / completion / inspection for react-i18next keys. -->
    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor language="JavaScript"
            implementation="com.webdx.i18n.I18nKeyReferenceContributor"/>

        <findUsagesHandlerFactory
            order="first"
            implementation="com.webdx.i18n.I18nKeyFindUsagesHandlerFactory"/>

        <localInspection language="TypeScript JSX"
            shortName="I18nUnknownKeyTsx"
            displayName="Unknown i18n translation key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nUnknownKeyInspection"/>
        <localInspection language="TypeScript"
            shortName="I18nUnknownKeyTs"
            displayName="Unknown i18n translation key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nUnknownKeyInspection"/>
        <localInspection language="JavaScript"
            shortName="I18nUnknownKeyJs"
            displayName="Unknown i18n translation key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nUnknownKeyInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="I18nUnknownKeyEs6"
            displayName="Unknown i18n translation key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nUnknownKeyInspection"/>
        <localInspection language="JSX Harmony"
            shortName="I18nUnknownKeyJsx"
            displayName="Unknown i18n translation key"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nUnknownKeyInspection"/>

        <localInspection language="TypeScript JSX"
            shortName="I18nInterpolationTsx"
            displayName="i18n interpolation variables"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nInterpolationInspection"/>
        <localInspection language="TypeScript"
            shortName="I18nInterpolationTs"
            displayName="i18n interpolation variables"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nInterpolationInspection"/>
        <localInspection language="JavaScript"
            shortName="I18nInterpolationJs"
            displayName="i18n interpolation variables"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nInterpolationInspection"/>
        <localInspection language="ECMAScript 6"
            shortName="I18nInterpolationEs6"
            displayName="i18n interpolation variables"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nInterpolationInspection"/>
        <localInspection language="JSX Harmony"
            shortName="I18nInterpolationJsx"
            displayName="i18n interpolation variables"
            groupName="JavaScript" enabledByDefault="true" level="WARNING"
            implementationClass="com.webdx.i18n.I18nInterpolationInspection"/>

        <completion.contributor language="TypeScript JSX" order="first"
            implementationClass="com.webdx.i18n.I18nOptionsCompletion"/>
        <completion.contributor language="TypeScript" order="first"
            implementationClass="com.webdx.i18n.I18nOptionsCompletion"/>
        <completion.contributor language="JavaScript" order="first"
            implementationClass="com.webdx.i18n.I18nOptionsCompletion"/>
        <completion.contributor language="ECMAScript 6" order="first"
            implementationClass="com.webdx.i18n.I18nOptionsCompletion"/>
        <completion.contributor language="JSX Harmony" order="first"
            implementationClass="com.webdx.i18n.I18nOptionsCompletion"/>
    </extensions>

    <applicationListeners>
        <listener class="com.webdx.cssmodules.CssScopedAppListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <actions>
        <!-- Override Go to Declaration to intercept styles.<class> (TS-Go bypasses the
             go-to extension points); delegates to default for everything else. -->
        <action id="GotoDeclaration" overrides="true"
                class="com.webdx.cssmodules.CssModuleGotoDeclarationAction"/>
    </actions>
</idea-plugin>
